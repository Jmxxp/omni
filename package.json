{
  "name": "omni",
  "version": "0.1.0",
  "private": true,
  "description": "Omni V1 - plug and play AI computer operator for Windows.",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:ui": "npm run dev -w @omni/desktop",
    "dev:core": "python services/core/server.py",
    "dev:stop": "powershell -ExecutionPolicy Bypass -File scripts/stop-dev.ps1",
    "build": "npm run build -w @omni/desktop",
    "typecheck": "npm run typecheck -w @omni/desktop",
    "tauri:dev": "npm run tauri:dev -w @omni/desktop",
    "tauri:build": "npm run tauri:build -w @omni/desktop"
  },
  "engines": {
    "node": ">=22",
    "npm": ">=10",
    "python": ">=3.11"
  }
}

