{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Omni",
  "version": "0.1.0",
  "identifier": "app.omni.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Omni",
        "width": 1180,
        "height": 760,
        "minWidth": 920,
        "minHeight": 640,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}

