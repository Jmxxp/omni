# LiveKit usado pela interface e pelo worker Python
LIVEKIT_URL=wss://seu-projeto.livekit.cloud
LIVEKIT_API_KEY=sua_livekit_api_key
LIVEKIT_API_SECRET=sua_livekit_api_secret

# Gemini usado pelo livekit-plugins-google
GOOGLE_API_KEY=sua_google_gemini_api_key

# Memoria de longo prazo
MEM0_API_KEY=sua_mem0_api_key
JARVIS_USER_ID=usuario_principal

# Desktop
JARVIS_AGENT_MODE=dev
JARVIS_AUTOSTART_AGENT=1
JARVIS_PORT=3217
